import { useState } from 'react';
import { cn } from './utils/cn';

// Types
interface Store {
  id: number;
  name: string;
  image: string;
  category: string;
  rating: number;
  reviews: number;
  distance: string;
  originalPrice: number;
  discountedPrice: number;
  bagsLeft: number;
  pickupTimes: string[];
  pickupEnd: string;
  description: string;
  address: string;
  city: string;
}

interface CartItem {
  store: Store;
  quantity: number;
  selectedTime: string;
}

